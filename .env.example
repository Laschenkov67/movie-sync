NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# PostgreSQL
DB_HOST=postgres
DB_PORT=5432
DB_USER=movies
DB_PASSWORD=movies
DB_NAME=movies
DB_LOGGING=false

# Redis (BullMQ)
REDIS_HOST=redis
REDIS_PORT=6379

# TMDB
TMDB_API_KEY=your_tmdb_api_key_here
TMDB_BASE_URL=https://api.themoviedb.org/3
TMDB_RATE_LIMIT_RPS=40
TMDB_REQUEST_TIMEOUT_MS=15000

# Sync
INITIAL_SYNC_PAGES=5
SYNC_CRON=*/15 * * * *
SYNC_BATCH_SIZE=20
SYNC_ENABLED=true